GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- RAG: Pinecone (default; use for local + production) ---
USE_PINECONE=true
# Must be an API key from the SAME Pinecone project you open in the browser.
# If the console shows "Record count 0" but verify_setup reports many vectors (or the reverse),
# you are mixing projects—create a key under that org/project and paste it here only in .env.
PINECONE_API_KEY=your_pinecone_api_key_here
# Serverless index name; dimension must be 384 for all-MiniLM-L6-v2
PINECONE_INDEX_NAME=whatsapp-rag-index-384
PINECONE_NAMESPACE=
# Main crawl + optional curated snippets (comma-separated; both recommended)
RAG_DATA_JSONL=data/commando_networks.jsonl,data/commando_curated_facts.jsonl
LOCAL_EMBED_MODEL=all-MiniLM-L6-v2

# --- Local Chroma only if USE_PINECONE=false (dev fallback) ---
CHROMA_DB_DIR=data/chroma_db

PORT=5000
